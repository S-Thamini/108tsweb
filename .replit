run = "python3 -m venv .venv && .venv/bin/pip install -r requirements.txt && .venv/bin/python3 main.py"
entrypoint = "main.py"

[packager]
language = "python3"

[nix]
channel = "stable-23_11"

[deployment]
run = ["bash", "-c", "python3 -m venv .venv && .venv/bin/pip install -r requirements.txt && .venv/bin/python3 main.py"]
